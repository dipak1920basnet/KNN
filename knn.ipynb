   "source": [
    "# Calculate the eculidean Distance from the points \n",
    "def euclidean_distance(point1, point2):\n",
    "    distance = np.sum((np.array(point1) - np.array(point2))**2)\n",
    "    return np.sqrt(distance)"
   ]
